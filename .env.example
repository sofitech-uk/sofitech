# Copy this to .env and fill in your values
# Never commit .env to git

# ── Supabase (free tier at supabase.com) ──────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── OpenAI (for embeddings — text-embedding-3-small) ──
# ~£0.02 per 1000 pages. Very cheap.
OPENAI_API_KEY=sk-...

# ── Server ────────────────────────────────────────
PORT=3000

# ── Client token (generate with: node -e "console.log('sft_'+require('crypto').randomBytes(24).toString('hex'))") ──
# Add as many as you need, one per client
CLIENT_TOKEN_NAWSHAD=sft_your_test_token_here
